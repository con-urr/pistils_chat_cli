{
  "name": "pistils-chat-cli",
  "version": "0.1.1",
  "description": "Tiny realtime SpaceTimeDB v2 CLI for agent-first live chat",
  "license": "Apache-2.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/con-urr/pistils_chat_cli.git"
  },
  "homepage": "https://github.com/con-urr/pistils_chat_cli#readme",
  "bugs": {
    "url": "https://github.com/con-urr/pistils_chat_cli/issues"
  },
  "keywords": [
    "agent",
    "chat",
    "realtime",
    "spacetimedb",
    "cli"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "agenttalk": "dist/agenttalk.js",
    "pistils-chat-cli": "dist/agenttalk.js",
    "agenttalkd": "dist/agenttalkd.js",
    "agenttalk-mcp": "dist/mcp-server.js",
    "agenttalk-supervisor": "dist/agenttalk-supervisor.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/agent-client.d.ts",
      "default": "./dist/agent-client.js"
    },
    "./wake": {
      "types": "./dist/wake.d.ts",
      "default": "./dist/wake.js"
    },
    "./daemon": {
      "types": "./dist/agenttalkd.d.ts",
      "default": "./dist/agenttalkd.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "default": "./dist/mcp/server.js"
    },
    "./supervisor": {
      "types": "./dist/supervisor/cli.d.ts",
      "default": "./dist/supervisor/cli.js"
    }
  },
  "files": [
    "dist",
    "docs/agenttalk-mcp-wake-supervisor-build-plan.md",
    "docs/agenttalk-mcp.md",
    "docs/agenttalk-supervisor.md",
    "docs/agenttalk-open-beta-architecture.md",
    "docs/agenttalk-wake-connectors.md",
    "docs/integrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "check": "npm run build && npm run smoke:cli-surface && npm run smoke:supervisor && npm run smoke:hermes-status && npm run smoke:wake-connectors && npm run smoke:setup && npm run pack:check",
    "smoke:cli-surface": "node scripts/smoke-cli-surface.mjs",
    "smoke:daemon-routing": "node scripts/smoke-daemon-routing.mjs",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "smoke:hermes-status": "node scripts/smoke-hermes-status.mjs",
    "smoke:real-connectors": "node scripts/smoke-real-connectors.mjs",
    "smoke:setup": "node scripts/smoke-setup.mjs",
    "smoke:supervisor": "node scripts/smoke-supervisor.mjs",
    "smoke:supervisor-live-codex-self-reply": "node scripts/smoke-supervisor-live-codex-self-reply.mjs",
    "smoke:supervisor-live-self-reply": "node scripts/smoke-supervisor-live-self-reply.mjs",
    "smoke:supervisor-live-reply": "node scripts/smoke-supervisor-live-reply.mjs",
    "smoke:supervisor-live": "node scripts/smoke-supervisor-live-wake.mjs",
    "smoke:wake-connectors": "node scripts/smoke-wake-connectors.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run check",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "spacetimedb": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.6.2"
  }
}
